# Device OS: PiOS (Debian)

# Polaris

POLARIS_CONTAINER_NAME="polaris"
POLARIS_PORT=5050
POLARIS_VOLUME_MUSIC="/filepacks/@music.lidarr"
POLARIS_VOLUME_CACHE="/filepacks/@music.lidarr/Polaris/cache"
POLARIS_VOLUME_DATA="/filepacks/@music.lidarr/Polaris/data"

# Portainer

PORTAINER_CONTAINER_NAME="portainer"
PORTAINER_PORT_HTTP=9000
PORTAINER_PORT_TCP_TUNNEL=8000
PORTAINER_PORT_WEB_UI=9443
